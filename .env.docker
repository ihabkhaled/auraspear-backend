# ============================================================================
# AuraSpear SOC Backend — Docker Environment Variables
# ============================================================================
# Copy this file to .env:  cp .env.docker .env
# Then fill in ALL required values before running docker compose up
# ============================================================================

# ---------- Database (PostgreSQL) ----------
POSTGRES_DB=auraspear_soc
POSTGRES_USER=auraspear
POSTGRES_PASSWORD=change-me-strong-password
# DATABASE_URL is auto-set by docker-compose.yml — no need to change here

# ---------- Redis ----------
# REDIS_HOST and REDIS_PORT are auto-set by docker-compose.yml
REDIS_PASSWORD=

# ---------- Application ----------
PORT=4000
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# ---------- JWT (REQUIRED) ----------
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---------- Encryption (REQUIRED) ----------
# Must be exactly 64 hex characters (32 bytes for AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONFIG_ENCRYPTION_KEY=

# ---------- Seeding (REQUIRED) ----------
# Strong password for the seeded admin account (12+ chars)
SEED_DEFAULT_PASSWORD=

# ---------- OIDC / Microsoft Entra ID (optional) ----------
# OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0
# OIDC_AUDIENCE=api://auraspear-soc
# OIDC_JWKS_URI=https://login.microsoftonline.com/{tenant-id}/discovery/v2.0/keys
# OIDC_CLIENT_ID=your-client-id

# ---------- AWS Bedrock AI (optional) ----------
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MOCK=true

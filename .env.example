# Database
DATABASE_URL="postgresql://auraspear:auraspear_secret@localhost:5432/auraspear_soc?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OIDC / Microsoft Entra ID
OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0
OIDC_AUDIENCE=api://auraspear-soc
OIDC_JWKS_URI=https://login.microsoftonline.com/{tenant-id}/discovery/v2.0/keys
OIDC_CLIENT_ID=your-client-id

# Application
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
CONFIG_ENCRYPTION_KEY=change-me-generate-a-32-byte-hex-key

# Connector Defaults
WAZUH_BASE_URL=https://wazuh-manager:55000
OPENSEARCH_BASE_URL=https://opensearch:9200
MISP_BASE_URL=https://misp:443
SHUFFLE_BASE_URL=https://shuffle:3001

# AWS Bedrock (for AI module)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

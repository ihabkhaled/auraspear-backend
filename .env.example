# ============================================================================
# AuraSpear SOC BFF — Environment Variables
# ============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================================

# ---------- Database (PostgreSQL) ----------
# Use "postgres" as host for Docker, "localhost" for host-based NestJS
POSTGRES_DB=auraspear_soc
POSTGRES_USER=auraspear
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL="postgresql://auraspear:change-me-strong-password@localhost:5432/auraspear_soc?schema=public"

# ---------- Redis ----------
# Use "redis" as host for Docker, "localhost" for host-based NestJS
# REDIS_PASSWORD must be >= 16 characters in production
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- pgAdmin (development only) ----------
PGADMIN_EMAIL=admin@auraspear.io
PGADMIN_PASSWORD=change-me
PGADMIN_PORT=5050

# ---------- OIDC / Microsoft Entra ID (optional) ----------
# Only needed when using OIDC authentication instead of email/password
OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0
OIDC_AUDIENCE=api://auraspear-soc
OIDC_JWKS_URI=https://login.microsoftonline.com/{tenant-id}/discovery/v2.0/keys
OIDC_CLIENT_ID=your-client-id

# ---------- Seeding ----------
# REQUIRED for prisma db seed — set a strong password (12+ chars)
SEED_DEFAULT_PASSWORD=
# Optional — connector credentials for seed data (defaults to obvious placeholders if unset)
SEED_WAZUH_PASSWORD=
SEED_WAZUH_INDEXER_PASSWORD=
SEED_GRAYLOG_PASSWORD=
SEED_VELOCIRAPTOR_PASSWORD=
SEED_GRAFANA_API_KEY=
SEED_INFLUXDB_TOKEN=
SEED_MISP_AUTH_KEY=
SEED_SHUFFLE_API_KEY=

# ---------- Rate Limiting ----------
# Global rate limit: max requests per TTL window (in milliseconds)
RATE_LIMIT_THROTTLE_TTL=30000
RATE_LIMIT_THROTTLE_LIMIT=250

# ---------- Application ----------
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3000

# ---------- Encryption ----------
# MUST be exactly 64 hex characters (32 bytes for AES-256-GCM)
# REQUIRED — generate before first run:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONFIG_ENCRYPTION_KEY=

# ---------- JWT ----------
# MUST be at least 64 hex characters
# REQUIRED — generate before first run:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---------- Connector Defaults (optional) ----------
# Per-tenant config is stored encrypted in the database.
# These are fallback defaults only.
WAZUH_MANAGER_URL=https://wazuh-manager:55000
WAZUH_INDEXER_URL=https://wazuh-indexer:9200
GRAYLOG_BASE_URL=http://graylog:9000
VELOCIRAPTOR_BASE_URL=https://velociraptor:8003
GRAFANA_BASE_URL=http://grafana:3000
INFLUXDB_BASE_URL=http://influxdb:8086
MISP_BASE_URL=https://misp:443
SHUFFLE_BASE_URL=http://shuffle:3001

# ---------- AWS Bedrock (AI module) ----------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0

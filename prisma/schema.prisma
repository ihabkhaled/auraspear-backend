  @@index([tenantId, type])
  @@index([tenantId, riskScore])
  @@map("entities")
}

model EntityRelation {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  fromEntityId String   @map("from_entity_id") @db.Uuid
  toEntityId   String   @map("to_entity_id") @db.Uuid
  relationType String   @map("relation_type") @db.VarChar(100)
  confidence   Float    @default(1.0)
  source       String?  @db.VarChar(255)
  metadata     Json?    @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromEntity Entity @relation("from_entity", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity   Entity @relation("to_entity", fields: [toEntityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([fromEntityId])
  @@index([toEntityId])
  @@index([tenantId, relationType])
  @@map("entity_relations")
}

// ─── Tenant Agent Configuration ─────────────────────────────

model TenantAgentConfig {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  agentId           String    @map("agent_id") @db.VarChar(50)
  isEnabled         Boolean   @default(true) @map("is_enabled")
  providerMode      String    @default("default") @map("provider_mode") @db.VarChar(100)
  model             String?   @db.VarChar(255)
  temperature       Float     @default(0.7)
  maxTokensPerCall  Int       @default(2048) @map("max_tokens_per_call")
  systemPrompt      String?   @map("system_prompt") @db.Text
  promptSuffix      String?   @map("prompt_suffix") @db.Text
  indexPatterns     String[]  @default([]) @map("index_patterns")
  tokensPerHour     Int       @default(50000) @map("tokens_per_hour")
  tokensPerDay      Int       @default(500000) @map("tokens_per_day")
  tokensPerMonth    Int       @default(5000000) @map("tokens_per_month")
  tokensUsedHour    Int       @default(0) @map("tokens_used_hour")
  tokensUsedDay     Int       @default(0) @map("tokens_used_day")
  tokensUsedMonth   Int       @default(0) @map("tokens_used_month")
  maxConcurrentRuns Int       @default(3) @map("max_concurrent_runs")
  triggerMode       String    @default("manual_only") @map("trigger_mode") @db.VarChar(30)
  triggerConfig     Json      @default("{}") @map("trigger_config")
  osintSources      Json      @default("[]") @map("osint_sources")
  outputFormat      String    @default("markdown") @map("output_format") @db.VarChar(20)
  presentationSkills String[] @default([]) @map("presentation_skills")
  lastResetHour     DateTime? @map("last_reset_hour")
  lastResetDay      DateTime? @map("last_reset_day")
  lastResetMonth    DateTime? @map("last_reset_month")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, agentId])
  @@index([tenantId])
  @@index([tenantId, agentId, isEnabled])
  @@map("tenant_agent_configs")
}


// ─── Tenants ─────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships      TenantMembership[]
  connectorConfigs ConnectorConfig[]
  caseCycles       CaseCycle[]
  cases            Case[]
  auditLogs        AuditLog[]
  aiAuditLogs      AiAuditLog[]
  savedQueries     SavedQuery[]
  alerts           Alert[]
  intelIocs        IntelIOC[]
  intelMispEvents  IntelMispEvent[]
  huntSessions         HuntSession[]
  logstashPipelineLogs LogstashPipelineLog[]
  incidents            Incident[]
  correlationRules     CorrelationRule[]
  vulnerabilities      Vulnerability[]
  aiAgents             AiAgent[]
  uebaEntities         UebaEntity[]
  uebaAnomalies        UebaAnomaly[]
  mlModels             MlModel[]
  attackPaths          AttackPath[]
  soarPlaybooks        SoarPlaybook[]
  soarExecutions       SoarExecution[]
  complianceFrameworks ComplianceFramework[]
  reports              Report[]
  reportTemplates      ReportTemplate[]
  systemHealthChecks      SystemHealthCheck[]
  systemMetrics           SystemMetric[]
  normalizationPipelines  NormalizationPipeline[]
  detectionRules          DetectionRule[]
  cloudAccounts           CloudAccount[]
  cloudFindings           CloudFinding[]
  rolePermissions         RolePermission[]
  permissionDefinitions   PermissionDefinition[]
  jobs                    Job[]
  refreshTokenFamilies    RefreshTokenFamily[]
  userSessions            UserSession[]
  llmConnectors           LlmConnector[]
  aiPromptTemplates       AiPromptTemplate[]
  aiFeatureConfigs        AiFeatureConfig[]
  aiUsageLedger           AiUsageLedger[]
  runbooks                Runbook[]
  entities                Entity[]
  entityRelations         EntityRelation[]
  tenantAgentConfigs      TenantAgentConfig[]
  osintSourceConfigs      OsintSourceConfig[]
  aiApprovalRequests      AiApprovalRequest[]
  aiExecutionFindings     AiExecutionFinding[]
  aiAgentSchedules        AiAgentSchedule[]
  aiFindingOutputLinks    AiFindingOutputLink[]
  aiJobRunSummaries       AiJobRunSummary[]

  @@map("tenants")
}

// ─── Permission Definitions ──────────────────────────────────

model PermissionDefinition {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  key         String   @db.VarChar(100)
  module      String   @db.VarChar(50)
  labelKey    String   @map("label_key") @db.VarChar(150)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([module])
  @@map("permission_definitions")
}

// ─── Role Permissions ────────────────────────────────────────

model RolePermission {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  role          UserRole
  permissionKey String   @map("permission_key") @db.VarChar(100)
  allowed       Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role, permissionKey])
  @@index([tenantId, role])
  @@map("role_permissions")
}

// ─── Users ───────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(320)
  name         String    @db.VarChar(255)
  passwordHash String?   @map("password_hash") @db.VarChar(255)
  oidcSub      String?   @unique @map("oidc_sub") @db.VarChar(255)
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  isProtected  Boolean   @default(false) @map("is_protected")
  lastLoginAt  DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships TenantMembership[]
  preference  UserPreference?
  refreshTokenFamilies RefreshTokenFamily[]
  sessions             UserSession[]

  @@map("users")
}

// ─── Tenant Membership ───────────────────────────────────────

model TenantMembership {
  id       String     @id @default(uuid()) @db.Uuid
  userId   String     @map("user_id") @db.Uuid
  tenantId String     @map("tenant_id") @db.Uuid
  role     UserRole   @default(SOC_ANALYST_L1)
  status   UserStatus @default(active)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_memberships")
}

// ─── User Preferences ────────────────────────────────────────

model UserPreference {
  id                 String  @id @default(uuid()) @db.Uuid
  userId             String  @unique @map("user_id") @db.Uuid
  theme              String  @default("system") @db.VarChar(20)
  language           String  @default("en") @db.VarChar(10)
  notificationsEmail Boolean @default(true) @map("notifications_email")
  notificationsInApp Boolean @default(true) @map("notifications_in_app")

  // Notification category preferences
  notifyCriticalAlerts  Boolean @default(true)  @map("notify_critical_alerts")
  notifyHighAlerts      Boolean @default(true)  @map("notify_high_alerts")
  notifyCaseAssignments Boolean @default(true)  @map("notify_case_assignments")
  notifyIncidentUpdates Boolean @default(true)  @map("notify_incident_updates")
  notifyComplianceAlerts Boolean @default(true) @map("notify_compliance_alerts")
  notifyCaseUpdates      Boolean @default(true)  @map("notify_case_updates")
  notifyCaseComments     Boolean @default(true)  @map("notify_case_comments")
  notifyCaseActivity     Boolean @default(true)  @map("notify_case_activity")
  notifyUserManagement   Boolean @default(true)  @map("notify_user_management")

  // Data retention preferences (days as string, e.g. '30', '90', '365', 'unlimited')
  retentionAlerts    String @default("90")  @map("retention_alerts") @db.VarChar(20)
  retentionLogs      String @default("90")  @map("retention_logs") @db.VarChar(20)
  retentionIncidents String @default("365") @map("retention_incidents") @db.VarChar(20)
  retentionAuditLogs String @default("365") @map("retention_audit_logs") @db.VarChar(20)
  dashboardDensity   DashboardDensity @default(comfortable) @map("dashboard_density")
  collapsedDashboardPanels DashboardPanelKey[] @default([]) @map("collapsed_dashboard_panels")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserSession {
  id          String                @id @default(uuid()) @db.Uuid
  familyId    String                @unique @map("family_id") @db.Uuid
  userId      String                @map("user_id") @db.Uuid
  tenantId    String                @map("tenant_id") @db.Uuid
  status      UserSessionStatus     @default(active)
  osFamily    UserSessionOsFamily   @default(unknown) @map("os_family")
  clientType  UserSessionClientType @default(unknown) @map("client_type")
  ipAddress   String?               @map("ip_address") @db.VarChar(64)
  userAgent   String?               @map("user_agent") @db.VarChar(1024)
  currentAccessJti String?          @map("current_access_jti") @db.VarChar(64)
  currentAccessExpiresAt DateTime?  @map("current_access_expires_at")
  lastSeenAt  DateTime              @map("last_seen_at")
  lastLoginAt DateTime              @map("last_login_at")
  revokedAt   DateTime?             @map("revoked_at")
  revokedByUserId String?           @map("revoked_by_user_id") @db.Uuid
  revokeReason    String?           @map("revoke_reason") @db.VarChar(100)
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  family RefreshTokenFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([userId, status])
  @@index([lastSeenAt])
  @@map("user_sessions")
}

model RefreshTokenFamily {
  id                String                   @id @db.Uuid
  userId            String                   @map("user_id") @db.Uuid
  tenantId          String                   @map("tenant_id") @db.Uuid
  currentGeneration Int                      @default(0) @map("current_generation")
  status            RefreshTokenFamilyStatus @default(active)
  revokedAt         DateTime?                @map("revoked_at")
  revokedReason     String?                  @map("revoked_reason") @db.VarChar(100)
  expiresAt         DateTime                 @map("expires_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rotations RefreshTokenRotation[]
  session   UserSession?

  @@index([tenantId, status])
  @@index([userId, status])
  @@map("refresh_token_families")
}

model RefreshTokenRotation {
  id               String                     @id @default(uuid()) @db.Uuid
  familyId         String                     @map("family_id") @db.Uuid
  generation       Int
  jtiHash          String                     @unique @map("jti_hash") @db.VarChar(64)
  parentRotationId String?                    @map("parent_rotation_id") @db.Uuid
  status           RefreshTokenRotationStatus @default(active)
  issuedAt         DateTime                   @default(now()) @map("issued_at")
  usedAt           DateTime?                  @map("used_at")
  replacedAt       DateTime?                  @map("replaced_at")
  replayedAt       DateTime?                  @map("replayed_at")
  expiresAt        DateTime                   @map("expires_at")

  family          RefreshTokenFamily    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  parentRotation  RefreshTokenRotation? @relation("RefreshTokenRotationChain", fields: [parentRotationId], references: [id], onDelete: SetNull)
  childRotations  RefreshTokenRotation[] @relation("RefreshTokenRotationChain")

  @@unique([familyId, generation])
  @@index([familyId, status])
  @@map("refresh_token_rotations")
}

// ─── Connector Configurations ────────────────────────────────

model ConnectorConfig {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  type            ConnectorType
  name            String        @db.VarChar(255)
  enabled         Boolean       @default(false)
  authType        AuthType      @default(basic) @map("auth_type")
  encryptedConfig String        @map("encrypted_config") @db.Text
  lastTestAt      DateTime?     @map("last_test_at")
  lastTestOk      Boolean?      @map("last_test_ok")
  lastError       String?       @map("last_error") @db.Text
  lastSyncAt      DateTime?     @map("last_sync_at")
  syncEnabled     Boolean       @default(true) @map("sync_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([tenantId])
  @@map("connector_configs")
}

// ─── Alerts ──────────────────────────────────────────────────

model Alert {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  externalId      String?       @map("external_id") @db.VarChar(500)
  title           String        @db.VarChar(1000)
  description     String?       @db.Text
  severity        AlertSeverity @default(medium)
  status          AlertStatus   @default(new_alert)
  source          String        @db.VarChar(50)
  ruleName        String?       @map("rule_name") @db.VarChar(500)
  ruleId          String?       @map("rule_id") @db.VarChar(100)
  agentName       String?       @map("agent_name") @db.VarChar(255)
  sourceIp        String?       @map("source_ip") @db.VarChar(45)
  destinationIp   String?       @map("destination_ip") @db.VarChar(45)
  mitreTactics    String[]      @default([]) @map("mitre_tactics")
  mitreTechniques String[]      @default([]) @map("mitre_techniques")
  rawEvent        Json?         @map("raw_event")
  acknowledgedBy  String?       @map("acknowledged_by") @db.VarChar(320)
  acknowledgedAt  DateTime?     @map("acknowledged_at")
  resolution      String?       @db.Text
  closedAt        DateTime?     @map("closed_at")
  closedBy        String?       @map("closed_by") @db.VarChar(320)
  timestamp       DateTime      @default(now())

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  aiSummary              String?   @map("ai_summary") @db.Text
  aiConfidence           Float?    @map("ai_confidence")
  aiSeveritySuggestion   String?   @map("ai_severity_suggestion") @db.VarChar(20)
  aiEscalationSuggestion String?   @map("ai_escalation_suggestion") @db.Text
  aiLastRunAt            DateTime? @map("ai_last_run_at")
  aiLastExecutionId      String?   @map("ai_last_execution_id") @db.Uuid
  aiStatus               String?   @map("ai_status") @db.VarChar(30)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([tenantId, severity])
  @@index([tenantId, status])
  @@index([tenantId, timestamp])
  @@index([tenantId, source])
  @@map("alerts")
}

// ─── Case Cycles ────────────────────────────────────────────

model CaseCycle {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  name        String          @db.VarChar(255)
  description String?         @db.Text
  status      CaseCycleStatus @default(active)
  startDate   DateTime        @map("start_date")
  endDate     DateTime?       @map("end_date")
  createdBy   String          @map("created_by") @db.VarChar(320)
  closedBy    String?         @map("closed_by") @db.VarChar(320)
  closedAt    DateTime?       @map("closed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cases  Case[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("case_cycles")
}

// ─── Cases ───────────────────────────────────────────────────

model Case {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  caseNumber   String       @unique @map("case_number") @db.VarChar(20)
  title        String       @db.VarChar(500)
  description  String?      @db.Text
  severity     CaseSeverity @default(medium)
  status       CaseStatus   @default(open)
  ownerUserId  String?      @map("owner_user_id") @db.Uuid
  createdBy    String?      @map("created_by") @db.VarChar(320)
  linkedAlerts String[]     @default([]) @map("linked_alerts")
  cycleId      String?      @map("cycle_id") @db.Uuid
  closedAt     DateTime?    @map("closed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycle    CaseCycle?     @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  notes     CaseNote[]
  comments  CaseComment[]
  timeline  CaseTimeline[]
  tasks     CaseTask[]
  artifacts CaseArtifact[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([cycleId])
  @@map("cases")
}

model CaseNote {
  id     String @id @default(uuid()) @db.Uuid
  caseId String @map("case_id") @db.Uuid
  author String @db.VarChar(320)
  body   String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_notes")
}

model CaseComment {
  id        String  @id @default(uuid()) @db.Uuid
  caseId    String  @map("case_id") @db.Uuid
  authorId  String  @map("author_id") @db.Uuid
  body      String  @db.Text
  isEdited  Boolean @default(false) @map("is_edited")
  isDeleted Boolean @default(false) @map("is_deleted")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  case     Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  mentions CaseCommentMention[]

  @@index([caseId, createdAt])
  @@index([authorId])
  @@map("case_comments")
}

model CaseCommentMention {
  id        String @id @default(uuid()) @db.Uuid
  commentId String @map("comment_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  comment CaseComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
  @@map("case_comment_mentions")
}

model CaseTimeline {
  id          String @id @default(uuid()) @db.Uuid
  caseId      String @map("case_id") @db.Uuid
  type        String @db.VarChar(50)
  actor       String @db.VarChar(320)

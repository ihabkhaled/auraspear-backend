// ─── AI Execution Findings ─────────────────────────────────

model AiExecutionFinding {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  sessionId       String    @map("session_id") @db.Uuid
  agentId         String    @map("agent_id") @db.VarChar(50)
  sourceModule    String    @map("source_module") @db.VarChar(50)
  sourceEntityId  String?   @map("source_entity_id") @db.VarChar(255)
  findingType     String    @map("finding_type") @db.VarChar(50)
  title           String    @db.VarChar(500)
  summary         String    @db.Text
  confidenceScore Float?    @map("confidence_score")
  severity        String?   @db.VarChar(20)
  evidenceJson    Json?     @map("evidence_json")
  recommendedAction String? @map("recommended_action") @db.Text
  status          String    @default("proposed") @db.VarChar(20)

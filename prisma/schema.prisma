// ─── AI Finding Output Links ─────────────────────────────

model AiFindingOutputLink {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  findingId        String   @map("finding_id") @db.Uuid
  jobId            String?  @map("job_id") @db.Uuid
  linkedModule     String   @map("linked_module") @db.VarChar(50)
  linkedEntityType String   @map("linked_entity_type") @db.VarChar(50)
  linkedEntityId   String   @map("linked_entity_id") @db.VarChar(255)
  relationshipType String   @default("produced_by") @map("relationship_type") @db.VarChar(30)
  createdAt        DateTime @default(now()) @map("created_at")

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  finding AiExecutionFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([findingId])
  @@index([tenantId, linkedModule, linkedEntityId])
  @@index([jobId])
  @@map("ai_finding_output_links")
}

// ─── AI Job Run Summaries ────────────────────────────────

model AiJobRunSummary {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  jobId           String    @map("job_id") @db.Uuid
  scheduleId      String?   @map("schedule_id") @db.Uuid
  jobKey          String    @map("job_key") @db.VarChar(80)
  agentId         String?   @map("agent_id") @db.VarChar(50)
  triggerType     String    @default("scheduled") @map("trigger_type") @db.VarChar(30)
  status          String    @default("pending") @db.VarChar(20)
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  durationMs      Int?      @map("duration_ms")
  providerKey     String?   @map("provider_key") @db.VarChar(100)
  modelKey        String?   @map("model_key") @db.VarChar(255)
  tokensUsed      Int       @default(0) @map("tokens_used")
  findingsCount   Int       @default(0) @map("findings_count")
  writebacksCount Int       @default(0) @map("writebacks_count")
  sourceModule    String?   @map("source_module") @db.VarChar(50)
  sourceEntityId  String?   @map("source_entity_id") @db.VarChar(255)
  summaryText     String?   @map("summary_text") @db.Text
  confidenceScore Float?    @map("confidence_score")
  errorMessage    String?   @map("error_message") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([jobId])
  @@index([scheduleId])
  @@index([tenantId, jobKey])
  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("ai_job_run_summaries")
}

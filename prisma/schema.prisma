}

// ─── SOAR Playbooks ─────────────────────────────────────────

model SoarPlaybook {
  id                String             @id @default(uuid()) @db.Uuid
  tenantId          String             @map("tenant_id") @db.Uuid
  name              String             @db.VarChar(255)
  description       String?            @db.Text
  status            SoarPlaybookStatus @default(draft)
  triggerType       SoarTriggerType    @default(manual) @map("trigger_type")
  triggerConditions Json?              @map("trigger_conditions")
  steps             Json               @default("[]")
  executionCount    Int                @default(0) @map("execution_count")
  lastExecutedAt    DateTime?          @map("last_executed_at")
  createdBy         String             @map("created_by") @db.VarChar(320)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  executions SoarExecution[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, triggerType])
  @@map("soar_playbooks")
}

// ─── SOAR Executions ────────────────────────────────────────

model SoarExecution {
  id             String              @id @default(uuid()) @db.Uuid
  tenantId       String              @map("tenant_id") @db.Uuid
  playbookId     String              @map("playbook_id") @db.Uuid
  status         SoarExecutionStatus @default(running)
  triggerSource  String?             @map("trigger_source") @db.VarChar(255)
  triggeredBy    String              @map("triggered_by") @db.VarChar(320)
  startedAt      DateTime            @default(now()) @map("started_at")
  completedAt    DateTime?           @map("completed_at")
  stepsCompleted Int                 @default(0) @map("steps_completed")
  totalSteps     Int                 @default(0) @map("total_steps")
  output         Json?
  error          String?             @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  playbook SoarPlaybook @relation(fields: [playbookId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([playbookId])
  @@index([tenantId, startedAt])
  @@map("soar_executions")
}

// ─── Compliance Frameworks ──────────────────────────────────

model ComplianceFramework {
  id             String             @id @default(uuid()) @db.Uuid
  tenantId       String             @map("tenant_id") @db.Uuid
  name           String             @db.VarChar(255)
  description    String?            @db.Text
  standard       ComplianceStandard
  version        String             @db.VarChar(50)
  totalControls  Int                @default(0) @map("total_controls")
  passedControls Int                @default(0) @map("passed_controls")
  failedControls Int                @default(0) @map("failed_controls")
  overallScore   Float              @default(0) @map("overall_score")
  lastAssessedAt DateTime?          @map("last_assessed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  controls ComplianceControl[]

  @@unique([tenantId, standard, version])
  @@index([tenantId])
  @@index([tenantId, standard])
  @@map("compliance_frameworks")
}

// ─── Compliance Controls ────────────────────────────────────

model ComplianceControl {
  id            String                  @id @default(uuid()) @db.Uuid
  frameworkId   String                  @map("framework_id") @db.Uuid
  controlNumber String                 @map("control_number") @db.VarChar(50)
  title         String                  @db.VarChar(500)
  description   String?                 @db.Text
  status        ComplianceControlStatus @default(not_assessed)
  evidence      String?                 @db.Text
  assessedAt    DateTime?               @map("assessed_at")
  assessedBy    String?                 @map("assessed_by") @db.VarChar(320)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  framework ComplianceFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  @@unique([frameworkId, controlNumber])
  @@index([frameworkId])
  @@index([frameworkId, status])
  @@map("compliance_controls")
}

// ─── Reports ────────────────────────────────────────────────

model Report {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  name        String       @db.VarChar(255)
  description String?      @db.Text
  type        ReportType   @default(custom)
  format      ReportFormat @default(pdf)
  status      ReportStatus @default(generating)
  generatedBy String       @map("generated_by") @db.VarChar(320)
  parameters  Json?
  fileUrl     String?      @map("file_url") @db.VarChar(1000)
  fileSize    BigInt?      @map("file_size")
  generatedAt DateTime?    @map("generated_at")

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("reports")
}

// ─── System Health Checks ───────────────────────────────────

model SystemHealthCheck {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  serviceName    String        @map("service_name") @db.VarChar(255)
  serviceType    ServiceType   @map("service_type")
  status         ServiceStatus @default(unknown)
  responseTimeMs Int?          @map("response_time_ms")
  lastCheckedAt  DateTime      @default(now()) @map("last_checked_at")
  errorMessage   String?       @map("error_message") @db.Text
  metadata       Json?

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, serviceType])
  @@index([tenantId, status])
  @@index([tenantId, lastCheckedAt])
  @@map("system_health_checks")
}

// ─── System Metrics ─────────────────────────────────────────

model SystemMetric {
  id         String     @id @default(uuid()) @db.Uuid
  tenantId   String     @map("tenant_id") @db.Uuid
  metricName String     @map("metric_name") @db.VarChar(255)
  metricType MetricType @map("metric_type")
  value      Float
  unit       String     @db.VarChar(50)
  tags       Json?
  recordedAt DateTime   @default(now()) @map("recorded_at")

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, metricType])
  @@index([tenantId, metricName])
  @@index([tenantId, recordedAt])
  @@map("system_metrics")
}

// ─── Normalization Pipelines ────────────────────────────────

model NormalizationPipeline {
  id              String                      @id @default(uuid()) @db.Uuid
  tenantId        String                      @map("tenant_id") @db.Uuid
  name            String                      @db.VarChar(255)
  description     String?                     @db.Text
  sourceType      NormalizationSourceType     @map("source_type")
  status          NormalizationPipelineStatus @default(active)
  parserConfig    Json                        @map("parser_config")
  fieldMappings   Json                        @map("field_mappings")
  processedCount  BigInt                      @default(0) @map("processed_count")
  errorCount      Int                         @default(0) @map("error_count")
  lastProcessedAt DateTime?                   @map("last_processed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, sourceType])
  @@map("normalization_pipelines")
}

// ─── Detection Rules ────────────────────────────────────────

model DetectionRule {
  id                 String                @id @default(uuid()) @db.Uuid
  tenantId           String                @map("tenant_id") @db.Uuid
  ruleNumber         String                @unique @map("rule_number") @db.VarChar(20)
  name               String                @db.VarChar(500)
  description        String?               @db.Text
  ruleType           DetectionRuleType     @map("rule_type")
  severity           DetectionRuleSeverity @default(medium)
  status             DetectionRuleStatus   @default(active)
  conditions         Json
  actions            Json
  hitCount           Int                   @default(0) @map("hit_count")
  falsePositiveCount Int                   @default(0) @map("false_positive_count")
  lastTriggeredAt    DateTime?             @map("last_triggered_at")
  createdBy          String                @map("created_by") @db.VarChar(320)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, ruleType])
  @@index([tenantId, severity])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("detection_rules")
}

// ─── Cloud Accounts ─────────────────────────────────────────

model CloudAccount {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @map("tenant_id") @db.Uuid
  provider        CloudProvider
  accountId       String             @map("account_id") @db.VarChar(255)
  alias           String?            @db.VarChar(255)
  status          CloudAccountStatus @default(connected)
  region          String?            @db.VarChar(100)
  lastScanAt      DateTime?          @map("last_scan_at")
  findingsCount   Int                @default(0) @map("findings_count")
  complianceScore Float              @default(0) @map("compliance_score")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  findings CloudFinding[]

  @@unique([tenantId, provider, accountId])
  @@index([tenantId])
  @@index([tenantId, provider])
  @@index([tenantId, status])
  @@map("cloud_accounts")
}

// ─── Cloud Findings ─────────────────────────────────────────

model CloudFinding {
  id               String               @id @default(uuid()) @db.Uuid
  tenantId         String               @map("tenant_id") @db.Uuid
  cloudAccountId   String               @map("cloud_account_id") @db.Uuid
  resourceType     String               @map("resource_type") @db.VarChar(255)
  resourceId       String               @map("resource_id") @db.VarChar(500)
  severity         CloudFindingSeverity @default(medium)
  title            String               @db.VarChar(500)
  description      String?              @db.Text
  status           CloudFindingStatus   @default(open)
  remediationSteps String?              @map("remediation_steps") @db.Text
  detectedAt       DateTime             @default(now()) @map("detected_at")
  resolvedAt       DateTime?            @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cloudAccount CloudAccount @relation(fields: [cloudAccountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, severity])
  @@index([tenantId, status])
  @@index([cloudAccountId])
  @@index([tenantId, detectedAt])
  @@map("cloud_findings")
}

// ─── Job Queue ─────────────────────────────────────────────

enum JobStatus {
  pending
  running
  completed
  failed
  retrying
  cancelled
}

enum JobType {
  connector_sync
  detection_rule_execution
  correlation_rule_execution
  normalization_pipeline
  soar_playbook
  hunt_execution
  ai_agent_task
  report_generation
}

model Job {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  type           JobType
  status         JobStatus @default(pending)
  payload        Json      @default("{}")
  result         Json?
  error          String?   @db.Text
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3) @map("max_attempts")
  idempotencyKey String?   @map("idempotency_key") @db.VarChar(255)
  scheduledAt    DateTime? @map("scheduled_at")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdBy      String?   @map("created_by") @db.VarChar(320)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, type, status])
  @@index([status, scheduledAt])
  @@map("jobs")
}

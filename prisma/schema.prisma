generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  GLOBAL_ADMIN
  PLATFORM_OPERATOR
  TENANT_ADMIN
  DETECTION_ENGINEER
  INCIDENT_RESPONDER
  THREAT_INTEL_ANALYST
  SOAR_ENGINEER
  THREAT_HUNTER
  SOC_ANALYST_L2
  SOC_ANALYST_L1
  EXECUTIVE_READONLY
  AUDITOR_READONLY
}

enum ConnectorType {
  wazuh
  graylog
  logstash
  velociraptor
  grafana
  influxdb
  misp
  shuffle
  bedrock
}

enum AuthType {
  basic
  api_key
  token
  iam
}

enum RefreshTokenFamilyStatus {
  active
  revoked
  expired
}

enum RefreshTokenRotationStatus {
  active
  used
  revoked
  replayed
}

enum CaseStatus {
  open
  in_progress
  closed
}

enum CaseSeverity {
  critical
  high
  medium
  low
}

enum AlertSeverity {
  critical
  high
  medium
  low
  info
}

enum AlertStatus {
  new_alert
  acknowledged
  in_progress
  resolved
  closed
  false_positive
}

enum HuntSessionStatus {
  running
  completed
  error
}

enum CaseCycleStatus {
  active
  closed
}

enum UserStatus {
  active
  inactive
  suspended
}


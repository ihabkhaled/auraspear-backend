generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  GLOBAL_ADMIN
  TENANT_ADMIN
  SOC_ANALYST_L2
  SOC_ANALYST_L1
  THREAT_HUNTER
  EXECUTIVE_READONLY
}

enum ConnectorType {
  wazuh
  graylog
  logstash
  velociraptor
  grafana
  influxdb
  misp
  shuffle
  bedrock
}

enum AuthType {
  basic
  api_key
  token
  iam
}

enum CaseStatus {
  open
  in_progress
  closed
}

enum CaseSeverity {
  critical
  high
  medium
  low
}

enum AlertSeverity {
  critical
  high
  medium
  low
  info
}

enum AlertStatus {
  new_alert
  acknowledged
  in_progress
  resolved
  closed
  false_positive
}

enum HuntSessionStatus {
  running
  completed
  error
}

enum CaseCycleStatus {
  active
  closed
}

enum UserStatus {
  active
  inactive
  suspended
}

// ─── Tenants ─────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships      TenantMembership[]
  connectorConfigs ConnectorConfig[]
  caseCycles       CaseCycle[]
  cases            Case[]
  auditLogs        AuditLog[]
  aiAuditLogs      AiAuditLog[]
  savedQueries     SavedQuery[]
  alerts           Alert[]
  intelIocs        IntelIOC[]
  intelMispEvents  IntelMispEvent[]
  huntSessions         HuntSession[]
  logstashPipelineLogs LogstashPipelineLog[]

  @@map("tenants")
}

// ─── Users ───────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(320)
  name         String    @db.VarChar(255)
  passwordHash String?   @map("password_hash") @db.VarChar(255)
  oidcSub      String?   @unique @map("oidc_sub") @db.VarChar(255)
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  isProtected  Boolean   @default(false) @map("is_protected")
  lastLoginAt  DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships TenantMembership[]
  preference  UserPreference?

  @@map("users")
}

// ─── Tenant Membership ───────────────────────────────────────

model TenantMembership {
  id       String     @id @default(uuid()) @db.Uuid
  userId   String     @map("user_id") @db.Uuid
  tenantId String     @map("tenant_id") @db.Uuid
  role     UserRole   @default(SOC_ANALYST_L1)
  status   UserStatus @default(active)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_memberships")
}

// ─── User Preferences ────────────────────────────────────────

model UserPreference {
  id                 String  @id @default(uuid()) @db.Uuid
  userId             String  @unique @map("user_id") @db.Uuid
  theme              String  @default("system") @db.VarChar(20)
  language           String  @default("en") @db.VarChar(10)
  notificationsEmail Boolean @default(true) @map("notifications_email")
  notificationsInApp Boolean @default(true) @map("notifications_in_app")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─── Connector Configurations ────────────────────────────────

model ConnectorConfig {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  type            ConnectorType
  name            String        @db.VarChar(255)
  enabled         Boolean       @default(false)
  authType        AuthType      @default(basic) @map("auth_type")
  encryptedConfig String        @map("encrypted_config") @db.Text
  lastTestAt      DateTime?     @map("last_test_at")
  lastTestOk      Boolean?      @map("last_test_ok")
  lastError       String?       @map("last_error") @db.Text
  lastSyncAt      DateTime?     @map("last_sync_at")
  syncEnabled     Boolean       @default(true) @map("sync_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type])
  @@index([tenantId])
  @@map("connector_configs")
}

// ─── Alerts ──────────────────────────────────────────────────

model Alert {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  externalId      String?       @map("external_id") @db.VarChar(500)
  title           String        @db.VarChar(1000)
  description     String?       @db.Text
  severity        AlertSeverity @default(medium)
  status          AlertStatus   @default(new_alert)
  source          String        @db.VarChar(50)
  ruleName        String?       @map("rule_name") @db.VarChar(500)
  ruleId          String?       @map("rule_id") @db.VarChar(100)
  agentName       String?       @map("agent_name") @db.VarChar(255)
  sourceIp        String?       @map("source_ip") @db.VarChar(45)
  destinationIp   String?       @map("destination_ip") @db.VarChar(45)
  mitreTactics    String[]      @default([]) @map("mitre_tactics")
  mitreTechniques String[]      @default([]) @map("mitre_techniques")
  rawEvent        Json?         @map("raw_event")
  acknowledgedBy  String?       @map("acknowledged_by") @db.VarChar(320)
  acknowledgedAt  DateTime?     @map("acknowledged_at")
  resolution      String?       @db.Text
  closedAt        DateTime?     @map("closed_at")
  closedBy        String?       @map("closed_by") @db.VarChar(320)
  timestamp       DateTime      @default(now())

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalId])
  @@index([tenantId, severity])
  @@index([tenantId, status])
  @@index([tenantId, timestamp])
  @@index([tenantId, source])
  @@map("alerts")
}

// ─── Case Cycles ────────────────────────────────────────────

model CaseCycle {
  id          String          @id @default(uuid()) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  name        String          @db.VarChar(255)
  description String?         @db.Text
  status      CaseCycleStatus @default(active)
  startDate   DateTime        @map("start_date")
  endDate     DateTime?       @map("end_date")
  createdBy   String          @map("created_by") @db.VarChar(320)
  closedBy    String?         @map("closed_by") @db.VarChar(320)
  closedAt    DateTime?       @map("closed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cases  Case[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("case_cycles")
}

// ─── Cases ───────────────────────────────────────────────────

model Case {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  caseNumber   String       @unique @map("case_number") @db.VarChar(20)
  title        String       @db.VarChar(500)
  description  String?      @db.Text
  severity     CaseSeverity @default(medium)
  status       CaseStatus   @default(open)
  ownerUserId  String?      @map("owner_user_id") @db.Uuid
  createdBy    String?      @map("created_by") @db.VarChar(320)
  linkedAlerts String[]     @default([]) @map("linked_alerts")
  cycleId      String?      @map("cycle_id") @db.Uuid
  closedAt     DateTime?    @map("closed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycle    CaseCycle?     @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  notes     CaseNote[]
  comments  CaseComment[]
  timeline  CaseTimeline[]
  tasks     CaseTask[]
  artifacts CaseArtifact[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([cycleId])
  @@map("cases")
}

model CaseNote {
  id     String @id @default(uuid()) @db.Uuid
  caseId String @map("case_id") @db.Uuid
  author String @db.VarChar(320)
  body   String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_notes")
}

model CaseComment {
  id        String  @id @default(uuid()) @db.Uuid
  caseId    String  @map("case_id") @db.Uuid
  authorId  String  @map("author_id") @db.Uuid
  body      String  @db.Text
  isEdited  Boolean @default(false) @map("is_edited")
  isDeleted Boolean @default(false) @map("is_deleted")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  case     Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  mentions CaseCommentMention[]

  @@index([caseId, createdAt])
  @@index([authorId])
  @@map("case_comments")
}

model CaseCommentMention {
  id        String @id @default(uuid()) @db.Uuid
  commentId String @map("comment_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  comment CaseComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@map("case_comment_mentions")
}

model CaseTimeline {
  id          String @id @default(uuid()) @db.Uuid
  caseId      String @map("case_id") @db.Uuid
  type        String @db.VarChar(50)
  actor       String @db.VarChar(320)
  description String @db.Text

  timestamp DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseId, timestamp])
  @@map("case_timeline")
}

model CaseTask {
  id          String @id @default(uuid()) @db.Uuid
  caseId      String @map("case_id") @db.Uuid
  title       String @db.VarChar(500)
  status      String @default("pending") @db.VarChar(20)
  assignee    String? @db.VarChar(320)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_tasks")
}

model CaseArtifact {
  id     String @id @default(uuid()) @db.Uuid
  caseId String @map("case_id") @db.Uuid
  type   String @db.VarChar(20)
  value  String @db.VarChar(2048)
  source String @default("manual") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("case_artifacts")
}

// ─── Threat Intel ────────────────────────────────────────────

model IntelIOC {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  iocValue  String   @map("ioc_value") @db.VarChar(1000)
  iocType   String   @map("ioc_type") @db.VarChar(50)
  source    String   @db.VarChar(100)
  severity  String   @db.VarChar(20)
  hitCount  Int      @default(0) @map("hit_count")
  firstSeen DateTime @default(now()) @map("first_seen")
  lastSeen  DateTime @default(now()) @map("last_seen")
  tags      String[] @default([])
  active    Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, iocValue, iocType])
  @@index([tenantId])
  @@index([tenantId, iocType])
  @@map("intel_iocs")
}

model IntelMispEvent {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  mispEventId    String   @map("misp_event_id") @db.VarChar(100)
  organization   String   @db.VarChar(255)
  threatLevel    String   @map("threat_level") @db.VarChar(20)
  info           String   @db.Text
  date           DateTime
  tags           Json     @default("[]")
  attributeCount Int      @default(0) @map("attribute_count")
  published      Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, mispEventId])
  @@index([tenantId])
  @@map("intel_misp_events")
}

// ─── Threat Hunting ──────────────────────────────────────────

model HuntSession {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  query       String            @db.Text
  status      HuntSessionStatus @default(running)
  startedAt   DateTime          @default(now()) @map("started_at")
  completedAt DateTime?         @map("completed_at")
  startedBy   String            @map("started_by") @db.VarChar(320)
  eventsFound Int               @default(0) @map("events_found")
  reasoning   String[]          @default([])
  uniqueIps       Int               @default(0) @map("unique_ips")
  threatScore     Int               @default(0) @map("threat_score")
  mitreTactics    String[]          @default([]) @map("mitre_tactics")
  mitreTechniques String[]          @default([]) @map("mitre_techniques")
  aiAnalysis      String?           @map("ai_analysis") @db.Text
  sourceType      String            @default("wazuh") @map("source_type") @db.VarChar(50)
  timeRange       String            @default("24h") @map("time_range") @db.VarChar(10)
  executedQuery   Json?             @map("executed_query")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events HuntEvent[]

  @@index([tenantId])
  @@index([tenantId, startedAt])
  @@map("hunt_sessions")
}

model HuntEvent {
  id            String   @id @default(uuid()) @db.Uuid
  huntSessionId String   @map("hunt_session_id") @db.Uuid
  timestamp     DateTime @default(now())
  severity      String   @db.VarChar(20)
  eventId       String   @map("event_id") @db.VarChar(255)
  sourceIp      String?  @map("source_ip") @db.VarChar(45)
  user          String?  @db.VarChar(320)
  description   String   @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  huntSession HuntSession @relation(fields: [huntSessionId], references: [id], onDelete: Cascade)

  @@index([huntSessionId])
  @@map("hunt_events")
}

// ─── Audit Logs ──────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  actor      String   @db.VarChar(320)
  role       UserRole
  action     String   @db.VarChar(100)
  resource   String   @db.VarChar(255)
  resourceId String?  @map("resource_id") @db.VarChar(255)
  details    String?  @db.Text
  ipAddress  String?  @map("ip_address") @db.VarChar(45)

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ─── AI Audit Logs ───────────────────────────────────────────

model AiAuditLog {
  id           String  @id @default(uuid()) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  actor        String  @db.VarChar(320)
  action       String  @db.VarChar(100)
  model        String  @db.VarChar(100)
  inputTokens  Int     @default(0) @map("input_tokens")
  outputTokens Int     @default(0) @map("output_tokens")
  prompt       String? @db.Text
  response     String? @db.Text
  durationMs   Int?    @map("duration_ms")

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("ai_audit_logs")
}

// ─── Saved Queries (Threat Hunting) ──────────────────────────

model SavedQuery {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  name        String  @db.VarChar(255)
  query       String  @db.Text
  description String? @db.Text
  createdBy   String  @map("created_by") @db.VarChar(320)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("saved_queries")
}

// ─── Application Logs ───────────────────────────────────────

model ApplicationLog {
  id               String   @id @default(uuid()) @db.Uuid
  level            String   @db.VarChar(10)
  message          String   @db.VarChar(2000)
  feature          String   @db.VarChar(100)
  action           String   @db.VarChar(100)
  functionName     String?  @map("function_name") @db.VarChar(255)
  className        String?  @map("class_name") @db.VarChar(255)
  tenantId         String?  @map("tenant_id") @db.Uuid
  actorUserId      String?  @map("actor_user_id") @db.Uuid
  actorEmail       String?  @map("actor_email") @db.VarChar(320)
  requestId        String?  @map("request_id") @db.VarChar(100)
  targetResource   String?  @map("target_resource") @db.VarChar(100)
  targetResourceId String?  @map("target_resource_id") @db.VarChar(255)
  outcome          String?  @db.VarChar(50)
  metadata         Json?
  stackTrace       String?  @map("stack_trace") @db.Text
  httpMethod       String?  @map("http_method") @db.VarChar(10)
  httpRoute        String?  @map("http_route") @db.VarChar(500)
  httpStatusCode   Int?     @map("http_status_code")
  sourceType       String?  @map("source_type") @db.VarChar(50)
  ipAddress        String?  @map("ip_address") @db.VarChar(45)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([level])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([actorUserId])
  @@index([actorEmail])
  @@index([feature])
  @@index([functionName])
  @@map("application_logs")
}

// ─── Data Explorer — Sync Jobs ──────────────────────────────

enum SyncJobStatus {
  running
  completed
  failed
}

/// Tracks each sync run for a connector, providing history, audit, and retry capability.
/// Source-of-truth for sync operations. Retention: 90 days (cron cleanup).
model ConnectorSyncJob {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  connectorType   ConnectorType @map("connector_type")
  status          SyncJobStatus @default(running)
  recordsSynced   Int           @default(0) @map("records_synced")
  recordsFailed   Int           @default(0) @map("records_failed")
  errorMessage    String?       @map("error_message") @db.Text
  errorCode       String?       @map("error_code") @db.VarChar(100)
  durationMs      Int?          @map("duration_ms")
  initiatedBy     String        @default("system") @map("initiated_by") @db.VarChar(320)
  cursor          String?       @db.VarChar(1000)
  startedAt       DateTime      @default(now()) @map("started_at")
  completedAt     DateTime?     @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, connectorType])
  @@index([tenantId, startedAt])
  @@index([status])
  @@map("connector_sync_jobs")
}

// ─── Data Explorer — Grafana Dashboards ─────────────────────

/// Synced Grafana dashboard metadata. Fetch detail live.
/// Indexed for search and browse. Retention: synced on demand, replaced on re-sync.
model GrafanaDashboard {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  uid         String   @db.VarChar(255)
  title       String   @db.VarChar(500)
  folderTitle String?  @map("folder_title") @db.VarChar(500)
  url         String   @db.VarChar(1000)
  tags        String[] @default([])
  type        String   @default("dash-db") @db.VarChar(50)
  isStarred   Boolean  @default(false) @map("is_starred")

  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, uid])
  @@index([tenantId])
  @@map("grafana_dashboards")
}

// ─── Data Explorer — Velociraptor ───────────────────────────

/// Synced Velociraptor endpoint metadata. Heavy details fetched live.
/// Retention: re-synced periodically, stale entries auto-removed after 7 days.
model VelociraptorEndpoint {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  clientId   String    @map("client_id") @db.VarChar(255)
  hostname   String    @db.VarChar(500)
  os         String?   @db.VarChar(100)
  osVersion  String?   @map("os_version") @db.VarChar(255)
  lastSeenAt DateTime? @map("last_seen_at")
  labels     String[]  @default([])
  ipAddress  String?   @map("ip_address") @db.VarChar(45)

  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, clientId])
  @@index([tenantId])
  @@index([tenantId, hostname])
  @@map("velociraptor_endpoints")
}

/// Synced Velociraptor hunt metadata.
model VelociraptorHunt {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  huntId      String   @map("hunt_id") @db.VarChar(255)
  description String?  @db.Text
  creator     String?  @db.VarChar(255)
  state       String?  @db.VarChar(50)
  artifacts   String[] @default([])
  totalClients    Int  @default(0) @map("total_clients")
  finishedClients Int  @default(0) @map("finished_clients")
  startedAt   DateTime? @map("started_at")

  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, huntId])
  @@index([tenantId])
  @@map("velociraptor_hunts")
}

/// Synced Velociraptor notebook metadata.
model VelociraptorNotebook {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  notebookId  String    @map("notebook_id") @db.VarChar(255)
  name        String    @db.VarChar(500)
  description String?   @db.Text
  creator     String?   @db.VarChar(255)
  modifiedAt  DateTime? @map("modified_at")

  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, notebookId])
  @@index([tenantId])
  @@map("velociraptor_notebooks")
}

// ─── Data Explorer — Logstash Pipeline Logs ─────────────────

/// Synced Logstash pipeline log entries. Seeded or synced from Logstash stats.
/// Indexed for search and browse. Retention: synced on demand, replaced on re-sync.
model LogstashPipelineLog {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  pipelineId     String   @map("pipeline_id") @db.VarChar(255)
  timestamp      DateTime @default(now())
  level          String   @db.VarChar(20)
  message        String   @db.Text
  source         String   @db.VarChar(255)
  eventsIn       Int      @default(0) @map("events_in")
  eventsOut      Int      @default(0) @map("events_out")
  eventsFiltered Int      @default(0) @map("events_filtered")
  durationMs     Float    @default(0) @map("duration_ms")
  metadata       Json?

  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, timestamp])
  @@index([tenantId, pipelineId])
  @@index([tenantId, level])
  @@map("logstash_pipeline_logs")
}

// ─── Data Explorer — Shuffle Workflows ──────────────────────

/// Synced Shuffle workflow metadata. Execution details fetched live.
model ShuffleWorkflow {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  workflowId   String   @map("workflow_id") @db.VarChar(255)
  name         String   @db.VarChar(500)
  description  String?  @db.Text
  isValid      Boolean  @default(false) @map("is_valid")
  triggerCount Int      @default(0) @map("trigger_count")
  tags         String[] @default([])

  syncedAt  DateTime @default(now()) @map("synced_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, workflowId])
  @@index([tenantId])
  @@map("shuffle_workflows")
}

// ─── Notifications ──────────────────────────────────────────

model Notification {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  type             String    @db.VarChar(50)
  actorUserId      String    @map("actor_user_id") @db.Uuid
  recipientUserId  String    @map("recipient_user_id") @db.Uuid
  title            String    @db.VarChar(500)
  message          String    @db.Text
  entityType       String    @map("entity_type") @db.VarChar(50)
  entityId         String    @map("entity_id") @db.Uuid
  caseId           String?   @map("case_id") @db.Uuid
  caseCommentId    String?   @map("case_comment_id") @db.Uuid
  readAt           DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([recipientUserId, caseCommentId])
  @@index([tenantId, recipientUserId, readAt, createdAt])
  @@index([tenantId, recipientUserId, createdAt])
  @@index([caseCommentId])
  @@map("notifications")
}

# Enforce LF line endings in the repo (matches Prettier endOfLine: lf)
* text=auto eol=lf

# Ensure shell scripts always use LF (even on Windows checkouts)
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
